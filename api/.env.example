# Copy to `.env` for local dev: `cp .env.example .env`
# The api loads `.env` on startup (dotenvy). Real process env vars always win;
# `.env` only fills gaps. All values below are the dev defaults baked into
# `src/config.rs` — you can run with an empty/absent `.env`. Production sets
# these on the service environment instead (see DEPLOY.md).

# --- MongoDB ---
BANDAO_MONGO_URI=mongodb://bandao:bandao@localhost:27017/bandao?authSource=admin
BANDAO_MONGO_DB=bandao

# --- HTTP server ---
# Default 127.0.0.1:8080 binds loopback only; use 0.0.0.0:8080 to expose.
BANDAO_LISTEN_ADDR=127.0.0.1:8080
# CORS: exact single origin the admin-web is served from (unset in dev).
# BANDAO_ALLOWED_ORIGIN=http://localhost:3000

# --- Sessions / cookies ---
BANDAO_SESSION_TTL_SECONDS=1209600
BANDAO_COOKIE_SECURE=false
# BANDAO_COOKIE_DOMAIN=

# --- External-database App-user auth ---
# AEAD key for encrypting external-auth DB connection passwords at rest.
# Required ONLY if an Org uses external-database auth; otherwise leave unset.
# Generate: `openssl rand -base64 32`. No rotation — changing it invalidates
# all stored external-auth passwords.
# BANDAO_SECRET_KEY=

# --- Logging ---
# tracing EnvFilter directive, e.g. `info`, `bandao_api=debug,tower_http=debug`.
# BANDAO_LOG=info
